# Default: let git decide. Repo policy is LF for source files; CRLF for
# explicitly-Windows files (.bat, .ps1, etc.) — those are fine as Windows-native.
* text=auto eol=lf

# === Force LF on anything that runs on Linux ================================
# Shell scripts, systemd units, Caddy configs, and similar must always be LF.
# Otherwise bash dies on the \r and systemd refuses to parse the unit.
# See docs/learnings/oci-relay-deploy-gotchas.md for the full failure-mode story.
*.sh             text eol=lf
*.bash           text eol=lf
*.service        text eol=lf
*.socket         text eol=lf
*.timer          text eol=lf
Caddyfile        text eol=lf
*.conf           text eol=lf
Dockerfile       text eol=lf
*.dockerignore   text eol=lf

# Node / web sources — LF everywhere is the modern default.
*.js             text eol=lf
*.mjs            text eol=lf
*.cjs            text eol=lf
*.ts             text eol=lf
*.json           text eol=lf
*.yaml           text eol=lf
*.yml            text eol=lf
*.md             text eol=lf

# Lua — UE4SS reads them on Windows but consistency with the rest of the
# tree (and Linux-side tooling) is cheaper than letting them drift to CRLF.
*.lua            text eol=lf

# === Windows-native files keep CRLF =========================================
# These run on Windows and tools may expect CRLF.
*.bat            text eol=crlf
*.cmd            text eol=crlf
*.ps1            text eol=crlf
*.psm1           text eol=crlf
*.vbs            text eol=crlf

# === Binary — never touch ===================================================
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.ico            binary
*.pak            binary
*.uasset         binary
*.uexp           binary
*.ubulk          binary
*.umap           binary
*.utoc           binary
*.ucas           binary
*.zip            binary
*.7z             binary
*.exe            binary
*.dll            binary
*.lib            binary
*.so             binary
*.bin            binary
*.blob           binary
*.ttf            binary
*.otf            binary
*.mp3            binary
*.wav            binary
*.ogg            binary
