{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/block-mcp-commit.ps1"
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/warn-hardcoded-path.ps1"
      }
    ],
    "stop": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/learnings-reminder.ps1"
      }
    ]
  }
}
